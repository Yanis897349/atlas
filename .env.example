# PostgreSQL database used by the Atlas application commands. Do not point this at the test database.
ATLAS_DATABASE_URL=postgres://postgres:postgres@localhost:5432/atlas?sslmode=disable

# Separate PostgreSQL database used only by integration tests. The test account must be able to create schemas.
ATLAS_TEST_DATABASE_URL=postgres://postgres:postgres@localhost:5432/atlas_test?sslmode=disable
