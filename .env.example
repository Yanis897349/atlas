# Host port published by the local PostgreSQL Compose service.
ATLAS_POSTGRES_PORT=5432

# PostgreSQL database used by the Atlas application commands. Do not point this at the test database.
ATLAS_DATABASE_URL=postgres://postgres:postgres@localhost:${ATLAS_POSTGRES_PORT}/atlas?sslmode=disable

# Separate PostgreSQL database used only by integration tests. The test account must be able to create schemas.
ATLAS_TEST_DATABASE_URL=postgres://postgres:postgres@localhost:${ATLAS_POSTGRES_PORT}/atlas_test?sslmode=disable

# OpenAI API credential shared by provider-backed commands.
ATLAS_OPENAI_API_KEY=

# OpenAI Responses API model used by the daily-brief command.
ATLAS_OPENAI_MODEL=

# OpenAI Embeddings API model used by source-record indexing and semantic search.
ATLAS_OPENAI_EMBEDDING_MODEL=
